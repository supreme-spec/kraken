# Smart Security Monitor — Environment Variables Example
# Copy to .env and adjust values

# Node.js server port
PORT=3000

# Сетевой интерфейс для привязки сервера.
# 0.0.0.0 — доступно в локальной сети (камеры/операторы). 127.0.0.1 — только локально.
HOST=0.0.0.0

# API-ключ аутентификации. Если задан — сервер требует его на ВСЕХ /api и /ws.
# Оставьте пустым для открытого локального режима (dev). Перед публикацией обязательно задайте!
# ВАЖНО: API_KEY (сервер) и VITE_API_KEY (клиент) должны совпадать.
API_KEY=
VITE_API_KEY=

# Python Face Engine URL
FACE_SERVER_URL=http://localhost:8001

# SQLite database path (relative to prisma/ directory)
DATABASE_URL="file:./dev.db"

# Node environment: development | production
NODE_ENV=development
