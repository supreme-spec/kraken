# Smart Security Monitor — Environment Variables Example
# Copy to .env and adjust values

# Node.js server port
PORT=3000

# Сетевой интерфейс для привязки сервера.
# 0.0.0.0 — доступно в локальной сети (камеры/операторы). 127.0.0.1 — только локально.
HOST=0.0.0.0

# API-ключ аутентификации. Если задан — сервер требует его на ВСЕХ /api и /ws.
# Оставьте пустым для открытого локального режима (dev). Перед публикацией обязательно задайте!
# ВАЖНО: API_KEY (сервер) и VITE_API_KEY (клиент) должны совпадать.
API_KEY=
VITE_API_KEY=

# Python Face Engine URL
FACE_SERVER_URL=http://localhost:8001

# API ключ для защиты /update-index на Python-сервере.
# Должен совпадать с FACE_API_KEY в окружении Python.
FACE_API_KEY=super-secret-change-me

# Путь к SQLite (для прямого чтения при старте, с WAL-режимом).
DB_PATH=prisma/dev.db

# SQLite database path (relative to prisma/ directory)
# Включите WAL-режим для конкурентных чтений/записей (Node.js пишет, Python читает).
# Если уже создана БД без WAL, выполните в SQLite: PRAGMA journal_mode=WAL;
DATABASE_URL="file:./dev.db?journal_mode=WAL"

# Node environment: development | production
NODE_ENV=development

# Порог распознавания лиц (проценты, 0-100).
# Для buffalo_l рекомендуется >= 55, чтобы избежать ложных срабатываний.
FACE_RECOGNITION_THRESHOLD=55
